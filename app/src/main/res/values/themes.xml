<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Appbansach" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/sage_primary</item>
        <item name="colorPrimaryVariant">@color/sage_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/sage_accent</item>
        <item name="colorSecondaryVariant">@color/sage_primary</item>
        <item name="colorOnSecondary">@color/text_main</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/sage_primary_dark</item>

        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/app_background</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>