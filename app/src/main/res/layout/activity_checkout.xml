<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                android:layout_marginBottom="8dp"
                app:tint="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin giao hàng"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardElevation="2dp"
                app:strokeWidth="2dp"
                app:strokeColor="#000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Họ và tên"
                        android:layout_marginBottom="12dp"
                        android:textColorHint="#000000"
                        app:hintTextColor="#000000"
                        app:boxStrokeColor="#000000"
                        app:boxStrokeWidth="2dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCheckoutName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#000000"
                            android:textStyle="bold"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Số điện thoại"
                        android:layout_marginBottom="12dp"
                        android:textColorHint="#000000"
                        app:hintTextColor="#000000"
                        app:boxStrokeColor="#000000"
                        app:boxStrokeWidth="2dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCheckoutPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textColor="#000000"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Địa chỉ chi tiết"
                        android:textColorHint="#000000"
                        app:hintTextColor="#000000"
                        app:boxStrokeColor="#000000"
                        app:boxStrokeWidth="2dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCheckoutAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#000000"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Voucher Sách -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã giảm giá sách"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/etVoucherCode"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:hint="Nhập mã giảm giá"
                    android:background="@drawable/bg_search"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"/>
                <Button
                    android:id="@+id/btnApplyVoucher"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="Áp dụng"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#1B4332"/>
            </LinearLayout>

            <!-- Voucher Vận chuyển -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã vận chuyển (Freeship)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <EditText
                    android:id="@+id/etShippingCode"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:hint="Nhập mã vận chuyển"
                    android:background="@drawable/bg_search"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"/>
                <Button
                    android:id="@+id/btnApplyShippingCode"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="Áp dụng"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#009688"/>
            </LinearLayout>

            <!-- Phương thức thanh toán -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phương thức thanh toán"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="12dp"/>

            <RadioGroup
                android:id="@+id/rgPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                <RadioButton
                    android:id="@+id/rbCOD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Thanh toán khi nhận hàng (COD)"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/rbTransfer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chuyển khoản ngân hàng"
                    android:textStyle="bold"
                    android:textColor="#000000" />
            </RadioGroup>

            <!-- Tổng kết tiền -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#DDDDDD">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tạm tính" android:textColor="#000000"/>
                        <TextView android:id="@+id/tvSubtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0đ" android:textColor="#000000" />
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phí vận chuyển" android:textColor="#000000"/>
                        <TextView android:id="@+id/tvShippingFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="30,000đ" android:textColor="#000000" />
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giảm giá sách" android:textColor="#000000"/>
                        <TextView android:id="@+id/tvDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0đ" android:textColor="#D60000" />
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giảm giá vận chuyển" android:textColor="#000000"/>
                        <TextView android:id="@+id/tvShippingDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0đ" android:textColor="#009688" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginBottom="12dp" />

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tổng thanh toán" android:textStyle="bold" android:textSize="18sp" android:textColor="#000000" />
                        <TextView android:id="@+id/tvCheckoutTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0đ" android:textColor="#1B4332" android:textStyle="bold" android:textSize="22sp" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaceOrder"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Xác nhận đặt hàng"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#1B4332"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

</RelativeLayout>
