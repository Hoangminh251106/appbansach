<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/app_background">

    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="60dp"
            app:cardBackgroundColor="@color/card_surface"
            app:strokeWidth="2dp"
            app:strokeColor="@color/sage_primary">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_myplaces" />
        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvProfileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đang tải..."
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_main"/>

    <TextView
        android:id="@+id/tvProfileEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="..."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPersonalInfo"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Thông tin cá nhân"
        android:layout_marginBottom="8dp"
        android:gravity="start|center_vertical"
        android:paddingStart="24dp"
        app:backgroundTint="@color/card_surface"
        android:textColor="@color/text_main"
        app:iconTint="@color/sage_primary_dark"
        app:icon="@android:drawable/ic_menu_info_details"
        app:cornerRadius="12dp"
        app:strokeColor="@color/sage_accent"
        app:strokeWidth="1dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUpdatePassword"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Cập nhật mật khẩu"
        android:layout_marginBottom="8dp"
        android:gravity="start|center_vertical"
        android:paddingStart="24dp"
        app:backgroundTint="@color/card_surface"
        android:textColor="@color/text_main"
        app:iconTint="@color/sage_primary_dark"
        app:icon="@android:drawable/ic_lock_idle_lock"
        app:cornerRadius="12dp"
        app:strokeColor="@color/sage_accent"
        app:strokeWidth="1dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOrderHistory"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/order_history"
        android:layout_marginBottom="8dp"
        android:gravity="start|center_vertical"
        android:paddingStart="24dp"
        app:backgroundTint="@color/card_surface"
        android:textColor="@color/text_main"
        app:iconTint="@color/sage_primary_dark"
        app:icon="@android:drawable/ic_menu_recent_history"
        app:cornerRadius="12dp"
        app:strokeColor="@color/sage_accent"
        app:strokeWidth="1dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnWishlist"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Sách yêu thích"
        android:layout_marginBottom="8dp"
        android:gravity="start|center_vertical"
        android:paddingStart="24dp"
        app:backgroundTint="@color/card_surface"
        android:textColor="@color/text_main"
        app:iconTint="@color/sage_primary_dark"
        app:icon="@android:drawable/btn_star_big_on"
        app:cornerRadius="12dp"
        app:strokeColor="@color/sage_accent"
        app:strokeWidth="1dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChatSupport"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Hỗ trợ trực tuyến"
        android:layout_marginBottom="8dp"
        android:gravity="start|center_vertical"
        android:paddingStart="24dp"
        app:backgroundTint="@color/card_surface"
        android:textColor="@color/text_main"
        app:iconTint="@color/sage_primary_dark"
        app:icon="@android:drawable/stat_notify_chat"
        app:cornerRadius="12dp"
        app:strokeColor="@color/sage_accent"
        app:strokeWidth="1dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAdminPanel"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/admin_panel"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        android:gravity="start|center_vertical"
        android:paddingStart="24dp"
        app:backgroundTint="#FFF3E0"
        android:textColor="#E65100"
        app:iconTint="#E65100"
        app:icon="@android:drawable/ic_lock_lock"
        app:cornerRadius="12dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/logout"
        app:backgroundTint="#E63946"
        android:textColor="@color/white"
        app:iconTint="@color/white"
        app:icon="@android:drawable/ic_lock_power_off"
        app:cornerRadius="16dp"/>

</LinearLayout>
