<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.bookstore.ui.auth.LoginFragment"
        android:label="Đăng nhập"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_forgotPasswordFragment"
            app:destination="@id/forgotPasswordFragment" />
        <action
            android:id="@+id/action_loginFragment_to_adminDashboardFragment"
            app:destination="@id/adminDashboardFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.bookstore.ui.auth.RegisterFragment"
        android:label="Đăng ký"
        tools:layout="@layout/fragment_register" />

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.example.bookstore.ui.auth.ForgotPasswordFragment"
        android:label="Quên mật khẩu"
        tools:layout="@layout/fragment_forgot_password" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.bookstore.ui.home.HomeFragment"
        android:label="Trang chủ"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookDetailFragment"
        android:name="com.example.bookstore.ui.detail.BookDetailFragment"
        android:label="Chi tiết sách"
        tools:layout="@layout/fragment_book_detail">
        <argument
            android:name="bookId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.bookstore.ui.cart.CartFragment"
        android:label="Giỏ hàng"
        tools:layout="@layout/fragment_cart">
        <action
            android:id="@+id/action_cartFragment_to_checkoutFragment"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.example.bookstore.ui.checkout.CheckoutFragment"
        android:label="Thanh toán"
        tools:layout="@layout/fragment_checkout" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.bookstore.ui.search.SearchFragment"
        android:label="Tìm kiếm"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.bookstore.ui.profile.ProfileFragment"
        android:label="Cá nhân"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_orderHistoryFragment"
            app:destination="@id/orderHistoryFragment" />
        <action
            android:id="@+id/action_profileFragment_to_adminDashboardFragment"
            app:destination="@id/adminDashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/orderHistoryFragment"
        android:name="com.example.bookstore.ui.profile.OrderHistoryFragment"
        android:label="Lịch sử đơn hàng"
        tools:layout="@layout/fragment_order_history" />

    <!-- Admin Section -->
    <fragment
        android:id="@+id/adminDashboardFragment"
        android:name="com.example.bookstore.ui.admin.AdminDashboardFragment"
        android:label="Quản trị"
        tools:layout="@layout/fragment_admin_dashboard">
        <action
            android:id="@+id/action_adminDashboardFragment_to_manageBooksFragment"
            app:destination="@id/manageBooksFragment" />
        <action
            android:id="@+id/action_adminDashboardFragment_to_manageOrdersFragment"
            app:destination="@id/manageOrdersFragment" />
        <action
            android:id="@+id/action_adminDashboardFragment_to_statisticsFragment"
            app:destination="@id/statisticsFragment" />
    </fragment>

    <fragment
        android:id="@+id/manageBooksFragment"
        android:name="com.example.bookstore.ui.admin.ManageBooksFragment"
        android:label="Quản lý sách"
        tools:layout="@layout/fragment_manage_books">
        <action
            android:id="@+id/action_manageBooksFragment_to_addEditBookFragment"
            app:destination="@id/addEditBookFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEditBookFragment"
        android:name="com.example.bookstore.ui.admin.AddEditBookFragment"
        android:label="Sách"
        tools:layout="@layout/fragment_add_edit_book">
        <argument
            android:name="book"
            app:argType="com.example.bookstore.data.model.Book"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/manageOrdersFragment"
        android:name="com.example.bookstore.ui.admin.ManageOrdersFragment"
        android:label="Quản lý đơn hàng"
        tools:layout="@layout/fragment_manage_orders" />

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.example.bookstore.ui.admin.StatisticsFragment"
        android:label="Thống kê"
        tools:layout="@layout/fragment_statistics" />

</navigation>